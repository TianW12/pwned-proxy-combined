{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: runserver",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000",
                "--settings=config.development_settings"
            ],
            "django": true,
            "justMyCode": true,
            "console": "integratedTerminal"
        }
    ]
}