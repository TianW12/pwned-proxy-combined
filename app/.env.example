# Example environment configuration for Pwned Proxy
# Run `../generate_env.sh` to create `.env` with random secrets.
# Afterwards set your HIBP key and domain names in the generated file.

# Django secret key
DJANGO_SECRET_KEY=<long-secret-key>

# These can be left empty; startup scripts will handle them
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=<long-secret-password>
HIBP_API_KEY=<dummy-hibp-key>
SERVICE_FQDN_APP=api.haveibeenpwned.mydomain.com
DOMAIN=api.haveibeenpwned.mydomain.com

# Set to 'true' to enable Django debug mode
DJANGO_DEBUG=false
